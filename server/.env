# JWT Secret - ganti dengan string random yang aman
JWT_SECRET=ganti_dengan_string_rahasia_yang_panjang_dan_random

# ===== SMTP untuk kirim OTP via Email =====
# Contoh pakai Gmail App Password:
# 1. Aktifkan 2FA di akun Google
# 2. Buat App Password di https://myaccount.google.com/apppasswords
# 3. Isi SMTP_USER dengan email Gmail, SMTP_PASS dengan App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=emailkamu@gmail.com
SMTP_PASS=app_password_16_digit
SMTP_FROM=emailkamu@gmail.com

# ===== Google Login (OAuth) =====
# Buat di https://console.cloud.google.com/apis/credentials
# 1. Buat OAuth 2.0 Client ID tipe "Web application"
# 2. Authorized JavaScript origins: https://garin.fankynas.cloud
# 3. Authorized redirect URIs: https://garin.fankynas.cloud
GOOGLE_CLIENT_ID=isi_dengan_client_id_dari_google_cloud_console.apps.googleusercontent.com

PORT=5017
